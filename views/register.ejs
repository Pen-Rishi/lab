<div class="auth-page">
  <div class="auth-card">
    <div style="text-align:center;font-size:3rem;margin-bottom:10px;">🦸</div>
    <h1>Join the Team</h1>
    <p class="subtitle">Register to access the Avengers Armory</p>

    <% if (error) { %>
      <div class="alert alert-danger">⚠️ <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success">✅ <%= success %></div>
      <div style="text-align:center;margin-top:20px;">
        <a href="/login" class="btn btn-primary">Login Now</a>
      </div>
    <% } else { %>
      <form action="/register" method="POST">
        <div class="form-group">
          <label class="form-label">Codename (Username)</label>
          <input type="text" name="username" class="form-input" placeholder="Choose a hero name" required>
        </div>
        <div class="form-group">
          <label class="form-label">Secret Identity (Password)</label>
          <input type="text" name="password" class="form-input" placeholder="Any password works!">
          <div style="font-size:0.75rem;color:var(--text-dim);margin-top:4px;">⚠️ A07: No password complexity requirements!</div>
        </div>
        <div class="form-group">
          <label class="form-label">Comm Link (Email)</label>
          <input type="email" name="email" class="form-input" placeholder="hero@avengers.com" required>
        </div>
        <div class="form-group">
          <label class="form-label">Full Name</label>
          <input type="text" name="full_name" class="form-input" placeholder="Your real name">
        </div>
        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;">🦸 Join the Avengers</button>
      </form>

      <div class="auth-divider">or</div>

      <div style="text-align:center;">
        <p style="color:var(--text-muted);font-size:0.85rem;">Already a hero?</p>
        <a href="/login" class="btn btn-secondary" style="width:100%;margin-top:10px;">Login</a>
      </div>
    <% } %>
  </div>
</div>
