<div class="error-page">
  <div class="error-code">404</div>
  <h2>Page Not Found</h2>
  <p class="text-muted mt-2"><%= typeof message !== 'undefined' ? message : 'This page was destroyed by Thanos! Snap!' %></p>
  <div style="font-size:5rem;margin:30px 0;">💥</div>
  <div style="display:flex;gap:16px;">
    <a href="/" class="btn btn-primary">🏠 Return to Home</a>
    <a href="/products" class="btn btn-secondary">🛡️ Browse Armory</a>
  </div>
  <div style="margin-top:40px;padding:20px;background:var(--dark-3);border-radius:var(--radius-md);border:1px solid var(--border);max-width:400px;">
    <p style="color:var(--text-muted);font-size:0.8rem;">💡 <strong>Tip:</strong> Try visiting <code>/debug</code> for sensitive information disclosure!</p>
  </div>
</div>
