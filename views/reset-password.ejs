<div class="container" style="padding:40px 0;">
  <div style="max-width:500px;margin:0 auto;">
    <div class="section-title">
      <h2>🔄 Forgot Access Code</h2>
      <p class="subtitle">A07: Weak password reset — predictable tokens!</p>
      <div class="accent-line"></div>
    </div>

    <div class="alert alert-warning">
      🎯 <strong>Auth Failure Lab:</strong> Password reset tokens are just MD5 of your email! Anyone who knows your email can reset your password. Also, no token expiry!
    </div>

    <% if (error) { %>
      <div class="alert alert-danger">⚠️ <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success">✅ <%= success %></div>
    <% } %>

    <div class="card" style="padding:24px;margin-bottom:20px;">
      <h3 style="margin-bottom:16px;">Request Password Reset</h3>
      <div class="form-group">
        <label class="form-label">Agent Email</label>
        <input type="email" id="reset-email" class="form-input" placeholder="tony@stark.com" value="tony@stark.com">
      </div>
      <button onclick="requestReset()" class="btn btn-primary btn-lg" style="width:100%;">📧 Send Reset Link</button>
    </div>

    <div id="reset-result" style="display:none;"></div>

    <div class="card" style="padding:24px;">
      <h4 style="margin-bottom:12px;">💡 How to exploit</h4>
      <p style="color:var(--text-muted);font-size:0.9rem;line-height:1.7;">
        The reset token is <code>MD5(email)</code> — completely predictable! Anyone can calculate it.
      </p>
      <div style="margin-top:12px;padding:12px;background:var(--dark-2);border-radius:var(--radius-sm);">
        <p style="color:var(--text-dim);font-size:0.8rem;font-family:'JetBrains Mono',monospace;">
          // Predictable token (A07):<br>
          token = MD5("tony@stark.com")<br>
          // Reset without email:<br>
          GET /reset-password/confirm?token=MD5(email)&email=tony@stark.com&new_password=hacked123
        </p>
      </div>
    </div>
  </div>
</div>

<script>
async function requestReset() {
  const email = document.getElementById('reset-email').value;
  const res = await fetch('/api/reset-password', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email })
  });
  const data = await res.json();
  const el = document.getElementById('reset-result');
  el.style.display = 'block';
  if (data.reset_link) {
    el.innerHTML = `<div class="card" style="padding:24px;border-color:var(--primary);">
      <h4 style="margin-bottom:12px;">✅ Reset Link Generated</h4>
      <p>Token: <code>${data.token}</code></p>
      <p>Link: <a href="${data.reset_link}" target="_blank"><code>${data.reset_link}</code></a></p>
      <p style="color:var(--warning);margin-top:10px;">⚠️ ${data.note}</p>
    </div>`;
  } else {
    el.innerHTML = `<div class="alert alert-danger">⚠️ ${data.error || 'Failed'}</div>`;
  }
}
</script>
