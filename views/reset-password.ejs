<div class="container" style="padding:40px 0;">
  <div style="max-width:500px;margin:0 auto;">
    <div class="section-title">
      <h2>🔄 Forgot Access Code</h2>
      <p class="subtitle">Reset your access credentials</p>
      <div class="accent-line"></div>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger">⚠️ <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success">✅ <%= success %></div>
    <% } %>

    <div class="card" style="padding:24px;margin-bottom:20px;">
      <h3 style="margin-bottom:16px;">Request Password Reset</h3>
      <div class="form-group">
        <label class="form-label">Agent Email</label>
        <input type="email" id="reset-email" class="form-input" placeholder="tony@stark.com" value="tony@stark.com">
      </div>
      <button onclick="requestReset()" class="btn btn-primary btn-lg" style="width:100%;">📧 Send Reset Link</button>
    </div>

    <div id="reset-result" style="display:none;"></div>

  </div>
</div>

<script>
async function requestReset() {
  const email = document.getElementById('reset-email').value;
  const res = await fetch('/api/reset-password', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email })
  });
  const data = await res.json();
  const el = document.getElementById('reset-result');
  el.style.display = 'block';
  if (data.reset_link) {
    el.innerHTML = `<div class="card" style="padding:24px;border-color:var(--primary);">
      <h4 style="margin-bottom:12px;">✅ Reset Link Generated</h4>
      <p>Token: <code>${data.token}</code></p>
      <p>Link: <a href="${data.reset_link}" target="_blank"><code>${data.reset_link}</code></a></p>
    </div>`;
  } else {
    el.innerHTML = `<div class="alert alert-danger">⚠️ ${data.error || 'Failed'}</div>`;
  }
}
</script>
