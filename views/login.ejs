<div class="auth-page">
  <div class="auth-card">
    <div style="text-align:center;font-size:3rem;margin-bottom:10px;">⚔️</div>
    <h1>Welcome Back</h1>
    <p class="subtitle">Assemble your gear, hero!</p>

    <% if (error) { %>
      <div class="alert alert-danger">
        ⚠️ <%= error %>
      </div>
    <% } %>

    <form action="/login" method="POST">
      <div class="form-group">
        <label class="form-label">Agent ID (Username)</label>
        <input type="text" name="username" class="form-input" placeholder="e.g., tony, steve, admin" required>
        <div style="font-size:0.75rem;color:var(--text-dim);margin-top:4px;">Try: <code>admin' --</code> for SQL injection!</div>
      </div>
      <div class="form-group">
        <label class="form-label">Access Code (Password)</label>
        <input type="text" name="password" class="form-input" placeholder="Enter your password" required>
        <div style="font-size:0.75rem;color:var(--text-dim);margin-top:4px;">Try: <code>' OR '1'='1</code> to bypass!</div>
      </div>
      <button type="submit" class="btn btn-primary btn-lg" style="width:100%;">🔓 Access Armory</button>
    </form>

    <div class="auth-divider">or</div>

    <div style="text-align:center;">
      <p style="color:var(--text-muted);font-size:0.85rem;">New recruit?</p>
      <a href="/register" class="btn btn-secondary" style="width:100%;margin-top:10px;">Create Account</a>
    </div>

    <div style="margin-top:20px;padding:16px;background:var(--dark-3);border-radius:var(--radius-sm);border:1px solid var(--border);">
      <p style="font-size:0.8rem;color:var(--text-muted);text-align:center;">
        🔐 <strong>Test Accounts</strong><br>
        Admin: <code>admin</code> / <code>admin123</code><br>
        Users: <code>tony</code> / <code>ironman</code>, <code>steve</code> / <code>america</code><br>
        or try SQLi: <code>admin' --</code> with any password!
      </p>
    </div>
  </div>
</div>
