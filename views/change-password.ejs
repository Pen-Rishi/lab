<div class="container" style="padding:40px 0;">
  <div style="max-width:500px;margin:0 auto;">
    <div class="section-title">
      <h2>🔑 Change Access Code</h2>
      <p class="subtitle">A04: No current password required!</p>
      <div class="accent-line"></div>
    </div>

    <div class="alert alert-warning">
      🎯 <strong>Insecure Design Lab:</strong> This form doesn't ask for your <em>current</em> password! Anyone with access to your session can change it. Also, no password strength requirements!
    </div>

    <% if (error) { %>
      <div class="alert alert-danger">⚠️ <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success">✅ <%= success %></div>
    <% } %>

    <div class="card" style="padding:24px;">
      <form action="/profile/change-password" method="POST">
        <div class="form-group">
          <label class="form-label">New Password</label>
          <input type="text" name="new_password" class="form-input" placeholder="Any password works! No rules!" value="password123">
          <div style="font-size:0.75rem;color:var(--text-dim);margin-top:4px;">No complexity requirements! Try <code>123</code></div>
        </div>
        <div class="form-group">
          <label class="form-label">Confirm Password</label>
          <input type="text" name="confirm_password" class="form-input" placeholder="Same as above" value="password123">
        </div>
        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;">🔄 Change Password</button>
      </form>
    </div>

    <div class="card" style="padding:24px;margin-top:20px;">
      <h4 style="margin-bottom:12px;">💡 What's wrong here?</h4>
      <ul style="color:var(--text-muted);font-size:0.85rem;line-height:1.8;padding-left:20px;">
        <li>❌ <strong>No current password verification</strong> — anyone with your session can change your password</li>
        <li>❌ <strong>No password strength requirements</strong> — <code>123</code> is accepted</li>
        <li>❌ <strong>No email notification</strong> — you won't know your password was changed</li>
        <li>❌ <strong>SQL Injection</strong> — password is interpolated directly into SQL</li>
      </ul>
    </div>
  </div>
</div>
