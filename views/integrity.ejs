<div class="container" style="padding:40px 0;">
  <div style="max-width:600px;margin:0 auto;">
    <div class="section-title">
      <h2>📦 Package Manager</h2>
      <p class="subtitle">Install and manage packages</p>
      <div class="accent-line"></div>
    </div>

    <div class="card" style="padding:24px;margin-bottom:20px;">
      <h3 style="margin-bottom:16px;">Install a Package (Simulated)</h3>
      <form action="/integrity/install" method="POST">
        <div class="form-group">
          <label class="form-label">Package Name</label>
          <input type="text" name="package_name" class="form-input" placeholder="e.g., avengers-utils" value="malicious-package-v1.0.0">
        </div>
        <div class="form-divider" style="text-align:center;color:var(--text-dim);margin:16px 0;">— or —</div>
        <div class="form-group">
          <label class="form-label">Package URL</label>
          <input type="text" name="package_url" class="form-input" placeholder="https://evil-npm-registry.com/package.tgz">
        </div>
        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;">📦 Install Package</button>
      </form>
    </div>

    <% if (result) { %>
      <div class="card" style="padding:24px;border-color:var(--warning);">
        <h4 style="color:var(--warning);margin-bottom:12px;">⚠️ Installation Result</h4>
        <pre><%= result %></pre>
      </div>
    <% } %>

  </div>
</div>
