<div class="container" style="padding:40px 0;">
  <div style="max-width:500px;margin:0 auto;text-align:center;">
    <div class="section-title">
      <h2>⏱️ Hero Voting</h2>
      <p class="subtitle">Vote for your favorite hero</p>
      <div class="accent-line"></div>
    </div>

    <div class="card" style="padding:40px;">
      <div style="font-size:4rem;margin-bottom:20px;">🏆</div>
      <h3 style="margin-bottom:10px;">Hero of the Month</h3>
      <p class="text-muted" style="margin-bottom:20px;">Vote for your favorite Avenger!</p>
      
      <div style="font-family:'Orbitron',monospace;font-size:3rem;font-weight:900;color:var(--secondary);margin-bottom:10px;">
        <%= attempts %>
      </div>
      <p class="text-muted" style="font-size:0.9rem;margin-bottom:24px;">Total votes cast</p>

      <form action="/rate-limit-demo/vote" method="POST">
        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;">🗳️ Vote +1</button>
      </form>

      <div style="margin-top:16px;">
        <a href="/rate-limit-demo" class="btn btn-sm btn-secondary">↻ Reset Counter</a>
      </div>
    </div>
  </div>
</div>
