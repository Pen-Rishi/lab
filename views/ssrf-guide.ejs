<div class="container" style="padding:40px 0;">
  <div style="max-width:700px;margin:0 auto;">
    <div class="section-title">
      <h2>🕸️ Network Request Tool</h2>
      <p class="subtitle">Fetch resources from remote URLs</p>
      <div class="accent-line"></div>
    </div>

    <div class="card" style="padding:24px;margin-bottom:20px;">
      <h3 style="margin-bottom:16px;">🔗 Available Endpoints</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="card" style="padding:16px;border-color:var(--accent);">
          <h4>🖼️ Avatar Fetch</h4>
          <p style="font-size:0.85rem;color:var(--text-muted);">Fetch images from URLs</p>
          <a href="/avatar" class="btn btn-sm btn-secondary" style="margin-top:8px;">Open</a>
        </div>
        <div class="card" style="padding:16px;border-color:var(--accent);">
          <h4>🔍 URL Probe</h4>
          <p style="font-size:0.85rem;color:var(--text-muted);">Check URL availability</p>
          <code style="font-size:0.8rem;">POST /api/ssrf/probe</code>
        </div>
      </div>
    </div>
  </div>
</div>
