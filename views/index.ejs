    margin-top:2px;
  }
  @keyframes csBorderPulse {
    0%,100% { border-color:rgba(226,54,54,0.25);box-shadow:0 0 15px rgba(226,54,54,0); }
    50% { border-color:rgba(226,54,54,0.5);box-shadow:0 0 20px rgba(226,54,54,0.1); }
