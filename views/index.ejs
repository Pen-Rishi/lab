  </div>

  <div class="hero-content" style="z-index:2;position:relative;">
    <!-- Avengers Logo Animation -->
    <div class="avengers-logo-wrap">
      <div class="avengers-a">
        <svg viewBox="0 0 120 120" width="120" height="120" class="a-svg">
          <polygon points="60,10 95,110 75,110 65,80 55,80 45,110 25,110" fill="none" stroke="#e23636" stroke-width="3" class="a-outline"/>
          <line x1="42" y1="70" x2="78" y2="70" stroke="#e23636" stroke-width="3" class="a-bar"/>
          <circle cx="60" cy="60" r="55" fill="none" stroke="rgba(226,54,54,0.3)" stroke-width="1.5" class="a-circle"/>
        </svg>
      </div>
    </div>

    <!-- Title with staggered animation -->
    <div class="hero-title-group">
      <div class="hero-badge animate-hero" style="animation-delay:0.5s;">⚡ Earth's Mightiest Marketplace</div>
      <h1 class="hero-main-title">
        <span class="title-line animate-hero" style="animation-delay:0.7s;">AVENGERS</span>
        <span class="title-line title-accent animate-hero" style="animation-delay:0.9s;">ARMORY</span>
      </h1>
      <div class="hero-subtitle animate-hero" style="animation-delay:1.1s;">
        <span class="subtitle-dash"></span>
        <span>ASSEMBLE FOR THE END GAME</span>
        <span class="subtitle-dash"></span>
      </div>
    </div>

    <!-- Character roster animation -->
    <div class="hero-roster animate-hero" style="animation-delay:1.4s;">
      <div class="roster-char" style="--i:0;">🤖<span>Iron Man</span></div>
      <div class="roster-char" style="--i:1;">⭐<span>Cap</span></div>
      <div class="roster-char" style="--i:2;">⚡<span>Thor</span></div>
      <div class="roster-char" style="--i:3;">💚<span>Hulk</span></div>
      <div class="roster-char" style="--i:4;">🕷️<span>Widow</span></div>
      <div class="roster-char" style="--i:5;">🏹<span>Hawkeye</span></div>
    </div>

    <!-- CTA buttons -->
    <div class="hero-cta animate-hero" style="animation-delay:1.8s;">
      <a href="/products" class="btn btn-primary btn-lg hero-btn">
        <span class="btn-glow"></span>
        Explore Armory →
      </a>
      <a href="/register" class="btn btn-secondary btn-lg hero-btn">Join the Team</a>
    </div>

    <!-- ConnectSecure branding banner -->
    <div class="cs-banner animate-hero" style="animation-delay:2.1s;">
      <div class="cs-banner-inner">
        <div class="cs-shield">🛡️</div>
        <div class="cs-text">
          <div class="cs-title">ConnectSecure</div>
          <div class="cs-sub">Vulnerability Testing Lab — For Authorized Testing Purposes Only</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Floating SVG icons */
  .float-icon {
    position:absolute;
    animation-timing-function:ease-in-out;
    animation-iteration-count:infinite;
    filter:blur(0.5px);
  }
  .fi-1  { top:8%;   left:5%;   animation:floatA 18s infinite, spinSlow 25s linear infinite; }
  .fi-2  { top:15%;  right:8%;  animation:floatB 22s infinite, spinSlow 30s linear infinite reverse; }
  .fi-3  { top:60%;  left:3%;   animation:floatC 20s infinite; }
  .fi-4  { bottom:10%;right:5%; animation:floatD 24s infinite, pulse 4s ease-in-out infinite; }
  .fi-5  { top:5%;   left:45%;  animation:floatE 16s infinite, spinSlow 20s linear infinite; }
  .fi-6  { top:40%;  right:3%;  animation:floatF 19s infinite; }
  .fi-7  { bottom:20%;left:15%; animation:floatG 14s infinite; transform-origin:center; }
  .fi-8  { top:25%;  left:12%;  animation:floatH 21s infinite, arcGlow 3s ease-in-out infinite; }
  .fi-9  { bottom:30%;right:12%;animation:floatI 17s infinite, spinSlow 15s linear infinite; }
  .fi-10 { top:65%;  right:10%; animation:floatJ 23s infinite; }
  .fi-11 { bottom:5%;left:40%;  animation:floatK 15s infinite, pulse 5s ease-in-out infinite; }
  .fi-12 { top:45%;  left:8%;   animation:floatL 26s infinite, spinSlow 35s linear infinite reverse; }

  @keyframes floatA {
    0%,100% { transform:translate(0,0) rotate(0deg); }
    25% { transform:translate(30px,-20px) rotate(5deg); }
    50% { transform:translate(-10px,-40px) rotate(-3deg); }
    75% { transform:translate(20px,-10px) rotate(8deg); }
  }
  @keyframes floatB {
    0%,100% { transform:translate(0,0) rotate(0deg); }
    25% { transform:translate(-25px,15px) rotate(-8deg); }
    50% { transform:translate(15px,35px) rotate(5deg); }
    75% { transform:translate(-20px,20px) rotate(-3deg); }
  }
  @keyframes floatC {
    0%,100% { transform:translate(0,0) rotate(0deg); }
    33% { transform:translate(40px,-30px) rotate(10deg); }
    66% { transform:translate(-15px,-50px) rotate(-5deg); }
  }
  @keyframes floatD {
    0%,100% { transform:translate(0,0) scale(1); }
    25% { transform:translate(-30px,-20px) scale(1.05); }
    50% { transform:translate(10px,-45px) scale(0.95); }
    75% { transform:translate(-20px,-15px) scale(1.02); }
  }
  @keyframes floatE {
    0%,100% { transform:translate(0,0); }
    50% { transform:translate(-20px,30px); }
  }
  @keyframes floatF {
    0%,100% { transform:translate(0,0) rotate(0deg); }
    33% { transform:translate(-35px,25px) rotate(12deg); }
    66% { transform:translate(10px,-20px) rotate(-8deg); }
  }
  @keyframes floatG {
    0%,100% { transform:translate(0,0) rotate(-15deg); }
    50% { transform:translate(25px,-40px) rotate(15deg); }
  }
  @keyframes floatH {
    0%,100% { transform:translate(0,0); }
    25% { transform:translate(20px,15px); }
    50% { transform:translate(-10px,30px); }
    75% { transform:translate(15px,10px); }
  }
  @keyframes floatI {
    0%,100% { transform:translate(0,0) rotate(0deg); }
    50% { transform:translate(-30px,-25px) rotate(45deg); }
  }
  @keyframes floatJ {
    0%,100% { transform:translate(0,0) rotate(0deg); }
    33% { transform:translate(-20px,-35px) rotate(-10deg); }
    66% { transform:translate(15px,-15px) rotate(5deg); }
  }
  @keyframes floatK {
    0%,100% { transform:translate(0,0); }
    50% { transform:translate(20px,-30px); }
  }
  @keyframes floatL {
    0%,100% { transform:translate(0,0); }
    25% { transform:translate(15px,-20px); }
    50% { transform:translate(-20px,-35px); }
    75% { transform:translate(10px,-10px); }
  }
  @keyframes spinSlow {
    from { transform:rotate(0deg); }
    to { transform:rotate(360deg); }
  }
  @keyframes pulse {
    0%,100% { opacity:1; }
    50% { opacity:0.5; }
  }
  @keyframes arcGlow {
    0%,100% { filter:blur(0.5px) drop-shadow(0 0 2px rgba(30,144,255,0)); }
    50% { filter:blur(0.5px) drop-shadow(0 0 8px rgba(30,144,255,0.3)); }
  }

  @media (max-width:768px) {
    .float-icon { transform:scale(0.6); }
    .fi-5,.fi-9,.fi-11,.fi-12 { display:none; }
  }

  /* Energy beams */
  .energy-beams { position:absolute;top:0;left:0;width:100%;height:100%;z-index:1;pointer-events:none; }
  .beam {
    position:absolute;
    background:linear-gradient(90deg, transparent, rgba(226,54,54,0.06), transparent);
    animation:beamSweep 8s ease-in-out infinite;
  }
  .beam-1 { top:20%;left:-100%;width:200%;height:1px;animation-delay:0s; }
  .beam-2 { top:50%;left:-100%;width:200%;height:1px;animation-delay:2s; }
  .beam-3 { top:80%;left:-100%;width:200%;height:1px;animation-delay:4s; }
  .beam-4 {
    top:-100%;left:50%;width:1px;height:200%;
    background:linear-gradient(180deg, transparent, rgba(30,144,255,0.05), transparent);
    animation:beamSweepV 10s ease-in-out infinite;
  }
  @keyframes beamSweep {
    0% { transform:translateX(-50%); opacity:0; }
    50% { transform:translateX(50%); opacity:1; }
    100% { transform:translateX(150%); opacity:0; }
  }
  @keyframes beamSweepV {
    0% { transform:translateY(-50%); opacity:0; }
    50% { transform:translateY(50%); opacity:1; }
    100% { transform:translateY(150%); opacity:0; }
  }

  /* Avengers A logo */
  .avengers-logo-wrap {
    margin-bottom:30px;
    display:flex;justify-content:center;
  }
  .avengers-a {
    position:relative;
    animation:logoFloat 4s ease-in-out infinite;
  }
  .a-svg { filter:drop-shadow(0 0 20px rgba(226,54,54,0.4)); }
  .a-outline {
    stroke-dasharray:400;
    stroke-dashoffset:400;
    animation:drawA 2s ease forwards 0.3s;
  }
  .a-bar {
    stroke-dasharray:40;
    stroke-dashoffset:40;
    animation:drawA 1s ease forwards 1.5s;
  }
  .a-circle {
    stroke-dasharray:350;
    stroke-dashoffset:350;
    animation:drawA 2.5s ease forwards 0.1s;
  }
  @keyframes drawA {
    to { stroke-dashoffset:0; }
  }
  @keyframes logoFloat {
    0%,100% { transform:translateY(0); }
    50% { transform:translateY(-8px); }
  }

  /* Title animations */
  .hero-title-group { margin-bottom:30px; }
  .animate-hero {
    opacity:0;
    transform:translateY(30px);
    animation:heroReveal 0.8s cubic-bezier(0.16,1,0.3,1) forwards;
  }
  @keyframes heroReveal {
    to { opacity:1;transform:translateY(0); }
  }

  .hero-main-title {
    display:flex;flex-direction:column;align-items:center;gap:0;
    margin:20px 0 16px;
  }
  .title-line {
    font-family:'Orbitron',monospace;
    font-size:5rem;
    font-weight:900;
    letter-spacing:0.2em;
    line-height:1.1;
    color:#fff;
    text-shadow:0 0 40px rgba(255,255,255,0.1);
  }
  .title-accent {
    background:linear-gradient(135deg, #e23636 0%, #ff6b6b 40%, #f5c518 100%);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
    background-clip:text;
    background-size:200% 200%;
    animation:gradientShift 4s ease infinite;
  }
  @keyframes gradientShift {
    0%,100% { background-position:0% 50%; }
    50% { background-position:100% 50%; }
  }

  .hero-subtitle {
    display:flex;align-items:center;justify-content:center;gap:16px;
    font-family:'Orbitron',monospace;
    font-size:1rem;
    letter-spacing:0.35em;
    color:rgba(226,54,54,0.8);
    text-transform:uppercase;
    margin-top:8px;
  }
  .subtitle-dash {
    display:inline-block;
    width:40px;height:1px;
    background:linear-gradient(90deg, transparent, rgba(226,54,54,0.6));
  }
  .subtitle-dash:last-child {
    background:linear-gradient(90deg, rgba(226,54,54,0.6), transparent);
  }

  /* Character roster */
  .hero-roster {
    display:flex;justify-content:center;gap:24px;
    margin:40px 0;flex-wrap:wrap;
  }
  .roster-char {
    display:flex;flex-direction:column;align-items:center;gap:6px;
    font-size:2.5rem;
    opacity:0;
    animation:charAppear 0.5s ease forwards calc(1.6s + var(--i) * 0.15s);
    cursor:default;
    transition:transform 0.3s ease;
  }
  .roster-char:hover {
    transform:scale(1.2) translateY(-4px);
  }
  .roster-char span {
    font-size:0.7rem;
    font-family:'Orbitron',monospace;
    color:var(--text-dim);
    letter-spacing:0.1em;
    text-transform:uppercase;
  }
  @keyframes charAppear {
    0% { opacity:0;transform:scale(0) rotate(-20deg); }
    60% { transform:scale(1.3) rotate(5deg); }
    100% { opacity:1;transform:scale(1) rotate(0); }
  }

  /* CTA buttons */
  .hero-cta {
    display:flex;gap:16px;justify-content:center;flex-wrap:wrap;
    margin-bottom:40px;
  }
  .hero-btn {
    position:relative;overflow:hidden;
  }
  .hero-btn .btn-glow {
    position:absolute;top:0;left:-100%;width:100%;height:100%;
    background:linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    animation:btnGlow 3s ease-in-out infinite;
  }
  @keyframes btnGlow {
    0% { left:-100%; }
    50% { left:100%; }
    100% { left:100%; }
  }

  /* ConnectSecure banner */
  .cs-banner {
    margin-top:10px;
  }
  .cs-banner-inner {
    display:inline-flex;align-items:center;gap:14px;
    padding:14px 32px;
    background:rgba(226,54,54,0.08);
    border:1px solid rgba(226,54,54,0.25);
    border-radius:12px;
    backdrop-filter:blur(8px);
    animation:csBorderPulse 3s ease-in-out infinite;
  }
  .cs-shield {
    font-size:1.8rem;
    animation:csShieldBounce 2s ease-in-out infinite;
  }
  .cs-text { text-align:left; }
  .cs-title {
    font-family:'Orbitron',monospace;
    font-size:1.1rem;
    font-weight:800;
