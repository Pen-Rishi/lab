        <ellipse cx="50" cy="50" rx="40" ry="25"/>
        <ellipse cx="50" cy="50" rx="28" ry="18"/>
        <circle cx="50" cy="50" r="10" fill="rgba(46,204,113,0.1)"/>
        <circle cx="50" cy="50" r="4" fill="rgba(46,204,113,0.2)"/>
